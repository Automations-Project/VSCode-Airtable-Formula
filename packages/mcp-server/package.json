{
  "name": "airtable-user-mcp",
  "version": "2.4.2",
  "mcpName": "io.github.Automations-Project/airtable-user-mcp",
  "description": "Community MCP server for Airtable. Schema inspection, table / field / view CRUD (including merge-safe filter / sort / group updates), formula validation, and extension management. Not affiliated with Airtable Inc.",
  "main": "src/index.js",
  "bin": {
    "airtable-user-mcp": "src/index.js"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "src/**/*.js",
    "src/**/*.mjs",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Automations-Project/VSCode-Airtable-Formula.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/Automations-Project/VSCode-Airtable-Formula/tree/main/packages/mcp-server#readme",
  "bugs": {
    "url": "https://github.com/Automations-Project/VSCode-Airtable-Formula/issues"
  },
  "author": {
    "name": "Nskha",
    "url": "https://github.com/automations-Project"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/automations-Project"
    },
    {
      "type": "individual",
      "url": "https://github.com/Automations-Project/VSCode-Airtable-Formula"
    }
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "airtable",
    "airtable-api",
    "mcp-server",
    "ai",
    "claude",
    "cursor",
    "formula",
    "schema",
    "automation",
    "no-code"
  ],
  "license": "MIT",
  "scripts": {
    "start": "node src/index.js",
    "login": "node src/login.js",
    "test": "node --test \"test/*.test.js\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "fetch-cookie": "^3.0.1",
    "node-fetch": "^3.3.2",
    "tough-cookie": "^4.1.3"
  },
  "optionalDependencies": {
    "otpauth": "^9.5.0",
    "patchright": "^1.58.2"
  }
